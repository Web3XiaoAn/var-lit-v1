# Copy to /var/lib/var-lit-v1/runtime.env, fill the three Lighter credentials, then:
# chmod 600 /var/lib/var-lit-v1/runtime.env
LIGHTER_PRIVATE_KEY=请填写_Lighter_API_私钥
LIGHTER_API_KEY_INDEX=请填写_API_KEY_INDEX
LIGHTER_ACCOUNT_INDEX=请填写_ACCOUNT_INDEX

# Server acceptance starts in observe. Switching to live is a separate manual gate.
STRATEGY_EXECUTION_MODE=observe
STRATEGY_ORDER_NOTIONAL_USD=500
STRATEGY_BUY_DYNAMIC_THRESHOLD_MIN_PCT=0.05
STRATEGY_SELL_DYNAMIC_THRESHOLD_MIN_PCT=-0.073
STRATEGY_MAX_NORMAL_ROUND_WEAR_BPS=1.0
STRATEGY_MAX_QUOTE_AGE_MS=600
STRATEGY_EARLY_EXIT_MINUTES=30

# The web panel stays on server loopback and is viewed only through SSH:
# ssh -N -L 18780:127.0.0.1:8780 var-lit
OPERATIONS_DASHBOARD_ENABLED=true
OPERATIONS_DASHBOARD_PORT=8780

# Runtime evidence stays outside Git. Runtime database writes are disabled so they
# cannot enter the trading hot path. The separate research systemd service copies
# rotating evidence into SQLite with low CPU/I/O priority.
VARIATIONAL_RUNTIME_DIR=/var/lib/var-lit-v1/runtime
RESEARCH_DATABASE_FILE=/var/lib/var-lit-v1/research/strategy_research.sqlite3
RESEARCH_DATABASE_ENABLED=false
RESEARCH_DATABASE_MAX_MIB=900
RESEARCH_DATABASE_SYNC_SECONDS=1
