# 复制为 .env 后填写。真实凭证只保存在本机，禁止提交。
# Lighter API 三项凭证：私钥、API Key序号、账户序号。
LIGHTER_PRIVATE_KEY=请填写_Lighter_API_私钥
LIGHTER_API_KEY_INDEX=请填写_API_KEY_INDEX
LIGHTER_ACCOUNT_INDEX=请填写_ACCOUNT_INDEX

# live=连续实盘；observe=只观察不新开仓。已有持仓始终继续管理平仓。
STRATEGY_EXECUTION_MODE=observe

# 每轮目标开仓金额，单位U；修改后重启脚本生效。
STRATEGY_ORDER_NOTIONAL_USD=200

# 做多Var/做空Lighter：动态BUY门槛必须严格大于该百分比；等于也禁止开仓。
STRATEGY_BUY_DYNAMIC_THRESHOLD_MIN_PCT=0.05

# 做空Var/做多Lighter：动态SELL门槛低于该百分比时禁止开仓；等于允许。
STRATEGY_SELL_DYNAMIC_THRESHOLD_MIN_PCT=-0.073

# 本地运行数据和研究数据库路径。示例使用项目同级目录，避免上传GitHub。
# 部署服务器时建议改成绝对路径；真实密钥仍只填写在本机 .env。
VARIATIONAL_RUNTIME_DIR=../var-lit-v1-local/runtime
RESEARCH_DATABASE_FILE=../var-lit-v1-local/research/strategy_research.sqlite3
RESEARCH_DATABASE_ENABLED=true
RESEARCH_DATABASE_MAX_MIB=900
RESEARCH_DATABASE_SYNC_SECONDS=1
